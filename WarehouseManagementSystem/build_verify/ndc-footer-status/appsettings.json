      "PlcType": 1,
      "IpAddress": "192.168.1.101",
      "Port": 502
    }
  ],
  "DataCleanup": {
    "RetentionDays": 30,
    "CleanupIntervalHours": 24
  },
  "ApplicationExpiration": {
    "Enabled": true,
    "ExpirationDate": "2028-12-18 10:15:59",
    "Message": "应用程序已过期。"
